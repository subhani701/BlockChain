# Copy to .env and adjust to match your environment.

# Port the Express API listens on.
PORT=4000

# Ganache JSON-RPC endpoint.
#   Ganache GUI  -> http://127.0.0.1:7545
#   Ganache CLI  -> http://127.0.0.1:8545
GANACHE_RPC_URL=http://127.0.0.1:7545

# Deployed ProductRegistry address.
# Leave blank to auto-detect from build/contracts/ProductRegistry.json
# (Truffle records the address per network after `truffle migrate`).
CONTRACT_ADDRESS=

# Index of the Ganache account used to send transactions (the manufacturer).
# Must match the account that deployed the contract (owner of registerBatch).
MANUFACTURER_ACCOUNT_INDEX=0

# Where to persist generated batches (relative to backend/).
DATA_FILE=./data/batches.json
